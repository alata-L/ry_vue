<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.SysUserUseDeptMapper">

	<delete id="deleteUserUseDeptByUserId" parameterType="Long">
		delete from sys_user_use_dept where user_id = #{userId}
	</delete>

	<delete id="deleteUserUseDept">
		delete from sys_user_use_dept where user_id in
		<foreach collection="array" item="userId" open="(" separator="," close=")">
			#{userId}
		</foreach>
	</delete>

	<insert id="batchUserUseDept">
		insert into sys_user_use_dept(user_id, dept_dict_code) values
		<foreach item="item" index="index" collection="list" separator=",">
			(#{item.userId}, #{item.deptDictCode})
		</foreach>
	</insert>

	<select id="selectDeptDictCodesByUserId" resultType="long">
		select dept_dict_code from sys_user_use_dept where user_id = #{userId} order by dept_dict_code
	</select>

</mapper>
